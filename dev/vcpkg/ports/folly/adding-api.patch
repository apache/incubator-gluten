+unsigned int available_concurrency() noexcept {
+#if defined(__linux__) && !defined(__ANDROID__)
+  cpu_set_t cpuset;
+  if (!sched_getaffinity(0, sizeof(cpuset), &cpuset)) {
+    auto count = CPU_COUNT(&cpuset);
+    if (count != 0) {
+      return count;
+    }
+  }
+#endif
+
+  return std::thread::hardware_concurrency();
+}
